{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/roadgraph_builder/road_graph.schema.json",
  "title": "Road graph (MVP JSON export)",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "nodes", "edges"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Document format version; increment when fields change incompatibly."
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional document metadata (e.g. sd_to_hd pipeline status)."
    }
  },
  "$defs": {
    "point2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "point2or3": {
      "description": "2-D or 3-D polyline vertex. z is present only in 3D builds.",
      "type": "object",
      "required": ["x", "y"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      }
    },
    "semantic_rule": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "edge_id": { "type": "string" },
        "value_kmh": { "type": "number" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "description": "Camera / perception observations merged into an edge (see camera_detections.schema.json)."
    },
    "lane_geometry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["lane_index", "offset_m", "centerline_m", "confidence"],
      "properties": {
        "lane_index": { "type": "integer", "minimum": 0 },
        "offset_m": { "type": "number" },
        "centerline_m": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 2
          }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "hd_block": {
      "type": "object",
      "additionalProperties": true,
      "description": "SD→HD enrichment: boundaries, semantics, quality.",
      "properties": {
        "tier": { "type": "string" },
        "target_tier": { "type": "string" },
        "quality": { "type": "string" },
        "note": { "type": "string" },
        "lane_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6,
          "description": "Inferred number of lanes for this edge (optional, added by infer-lane-count)."
        },
        "lanes": {
          "type": "array",
          "items": { "$ref": "#/$defs/lane_geometry" },
          "description": "Per-lane geometry list (optional, added by infer-lane-count)."
        },
        "lane_inference_sources": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Sources used by infer-lane-count."
        },
        "lane_boundaries": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "left": {
              "type": "array",
              "items": { "$ref": "#/$defs/point2" }
            },
            "right": {
              "type": "array",
              "items": { "$ref": "#/$defs/point2" }
            }
          }
        },
        "semantic_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/semantic_rule" }
        },
        "vertical_model": { "type": "string" },
        "elevation_m": { "type": ["number", "null"] },
        "slope_deg": {
          "type": "number",
          "description": "Edge slope in degrees: positive = uphill in forward direction (3D1)."
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "position"],
      "properties": {
        "id": { "type": "string" },
        "position": { "$ref": "#/$defs/point2" },
        "attributes": {
          "type": "object",
          "additionalProperties": true,
          "description": "e.g. degree, junction_hint, hd",
          "properties": {
            "hd": { "$ref": "#/$defs/hd_block" },
            "elevation_m": {
              "type": "number",
              "description": "Node elevation in metres (3D1)."
            }
          }
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "start_node_id", "end_node_id", "polyline", "attributes"],
      "properties": {
        "id": { "type": "string" },
        "start_node_id": { "type": "string" },
        "end_node_id": { "type": "string" },
        "polyline": {
          "type": "array",
          "items": { "$ref": "#/$defs/point2or3" }
        },
        "attributes": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "hd": { "$ref": "#/$defs/hd_block" },
            "slope_deg": {
              "type": "number",
              "description": "Edge slope in degrees (3D1, positive = uphill in forward dir)."
            },
            "polyline_z": {
              "type": "array",
              "items": { "type": "number" },
              "description": "Per-vertex elevation values (3D1), one per polyline point."
            }
          }
        }
      }
    }
  }
}
