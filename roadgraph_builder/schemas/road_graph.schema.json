{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/roadgraph_builder/road_graph.schema.json",
  "title": "Road graph (MVP JSON export)",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "nodes", "edges"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Document format version; increment when fields change incompatibly."
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    }
  },
  "$defs": {
    "point2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "position"],
      "properties": {
        "id": { "type": "string" },
        "position": { "$ref": "#/$defs/point2" }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "start_node_id", "end_node_id", "polyline", "attributes"],
      "properties": {
        "id": { "type": "string" },
        "start_node_id": { "type": "string" },
        "end_node_id": { "type": "string" },
        "polyline": {
          "type": "array",
          "items": { "$ref": "#/$defs/point2" }
        },
        "attributes": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
