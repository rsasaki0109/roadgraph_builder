{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rsasaki0109/roadgraph_builder/camera_detections.schema.json",
  "title": "Camera / perception observations (edge-keyed)",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "format_version": {
      "type": "integer",
      "minimum": 1
    },
    "observations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["edge_id", "kind"],
        "properties": {
          "edge_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "value_kmh": { "type": "number" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  },
  "required": ["observations"]
}
